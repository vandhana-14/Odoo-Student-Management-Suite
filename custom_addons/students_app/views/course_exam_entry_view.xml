<odoo>
    <data>

        <!-- Course + Exam Entry Form -->
        <record id="view_course_exam_entry_form" model="ir.ui.view">
            <field name="name">student.exam.course.entry.form</field>
            <field name="model">student.exam</field>
            <field name="arch" type="xml">
                <form string="Course and Exam Entry">
                    <sheet>
                        <group string="Course Entry">
                            <field name="subject_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="code" string="Course ID"/>
                                    <field name="name" string="Course Name"/>
                                    <field name="semester" string="Semester"/>
                                </list>
                            </field>
                        </group>

                        <group string="Exam Entry" col="2">
                            <field name="department_id"/>
                            <field name="semester"/>
                            <field name="category"/>
                            <field name="exam_date"/>
                            <field name="subject_ids"
                                   string="Linked Courses"
                                   widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_course_exam_entry_list" model="ir.ui.view">
            <field name="name">student.exam.course.entry.list</field>
            <field name="model">student.exam</field>
            <field name="arch" type="xml">
                <list string="Course and Exam Entries">
                    <field name="department_id"/>
                    <field name="semester"/>
                    <field name="category"/>
                    <field name="exam_date"/>
                </list>
            </field>
        </record>

        <record id="action_course_exam_entry" model="ir.actions.act_window">
            <field name="name">Course &amp; Exam Entry</field>
            <field name="res_model">student.exam</field>
            <field name="view_mode">form,list</field>
            <field name="view_id" ref="view_course_exam_entry_form"/>
        </record>

        <menuitem id="menu_course_exam_entry"
                  name="Course &amp; Exam Entry"
                  parent="students_app.menu_student_root"
                  action="action_course_exam_entry"
                  sequence="7"/>

    </data>
</odoo>
