<odoo>

    <!-- Student Marks Menu -->
    <record id="action_student_score" model="ir.actions.act_window">
        <field name="name">Semester Marks</field>
        <field name="res_model">student.score.record</field>
        <field name="view_mode">form,list</field>
    </record>

    <menuitem id="menu_student_score"
              name="Semester Marks"
              parent="students_app.menu_student_root"
              action="action_student_score"
              sequence="20"/>


    <!-- Search View -->
    <record id="view_student_score_search" model="ir.ui.view">
        <field name="name">student.score.search</field>
        <field name="model">student.score.record</field>
        <field name="arch" type="xml">

            <search string="Search Marks">

                <field name="semester"/>

                <field name="category"/>
                <field name="student_id"/>

                <filter string="Cycle Test 1"
                        name="cycle1"
                        domain="[('category','=','cycle1')]"/>

                <filter string="Cycle Test 2"
                        name="cycle2"
                        domain="[('category','=','cycle2')]"/>

                <filter string="Semester Exam"
                        name="semester"
                        domain="[('category','=','semester')]"/>

            </search>

        </field>
    </record>

    <!-- Form View -->
    <record id="view_student_score_form" model="ir.ui.view">
        <field name="name">student.score.form</field>
        <field name="model">student.score.record</field>
        <field name="arch" type="xml">

            <form string="Semester Marks">
                <sheet>
                    <group string="Student &amp; Exam Filters" col="2">
                        <field name="student_id"/>
                        <field name="student_name" readonly="1"/>
                        <field name="department_id" readonly="1"/>
                        <field name="category"/>
                        <field name="semester"/>
                    </group>

                    <group>
                        <button name="action_fetch_results"
                                string="Fetch Results"
                                type="object"
                                class="btn-primary"/>
                    </group>

                    <group string="Exam Results">
                        <field name="line_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false">
                                <field name="course_id"/>
                                <field name="course_name"/>
                                <field name="exam_date"/>
                                <field name="total_mark"/>
                                <field name="obtained_mark"/>
                                <field name="grade"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>

        </field>
    </record>


    <!-- Table View -->
    <record id="view_student_score_list" model="ir.ui.view">
        <field name="name">student.score.list</field>
        <field name="model">student.score.record</field>
        <field name="arch" type="xml">

            <list string="Semester Marks">

                <field name="student_id"/>
                <field name="student_name"/>
                <field name="department_id"/>
                <field name="category"/>
                <field name="semester"/>

            </list>

        </field>
    </record>

    <!-- Action View Order -->
    <record id="action_student_score_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_student_score_form"/>
        <field name="act_window_id" ref="action_student_score"/>
    </record>

    <record id="action_student_score_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_student_score_list"/>
        <field name="act_window_id" ref="action_student_score"/>
    </record>

</odoo>
