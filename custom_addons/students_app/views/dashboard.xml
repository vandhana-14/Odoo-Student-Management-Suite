<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="spreadsheet_dashboard_group_student" model="spreadsheet.dashboard.group">
        <field name="name">Student</field>
        <field name="sequence">300</field>
    </record>

    <record id="spreadsheet_dashboard_student" model="spreadsheet.dashboard">
        <field name="name">Student</field>
        <field name="spreadsheet_binary_data" type="base64" file="students_app/data/files/student.json"/>
        <field name="main_data_model_ids" eval="[(4, ref('students_app.model_student_student')), (4, ref('students_app.model_student_marks'))]"/>
        <field name="dashboard_group_id" ref="students_app.spreadsheet_dashboard_group_student"/>
        <field name="sequence">300</field>
        <field name="is_published">True</field>
    </record>
</odoo>
