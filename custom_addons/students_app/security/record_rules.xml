<odoo>
    <data>

        <!-- Student can see only their own record -->
        <record id="student_own_record_rule" model="ir.rule">
            <field name="name">Student: Own Record Only</field>
            <field name="model_id" ref="model_student_student"/>
            <field name="domain_force">[('user_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('students_app.group_student_user'))]"/>
        </record>

    </data>
</odoo>