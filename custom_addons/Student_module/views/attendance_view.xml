
<odoo>
    <data>

        <!-- ===================== -->
        <!-- ATTENDANCE LIST (READ ONLY) -->
        <!-- ===================== -->
        <record id="view_student_attendance_list" model="ir.ui.view">
            <field name="name">student.attendance.list</field>
            <field name="model">student.attendance</field>
            <field name="arch" type="xml">

                <list string="Student Attendance"
                      create="false"
                      edit="false"
                      delete="false">

                    <field name="image" widget="image"  options="{'size': [70,70]}" class="oe_avatar"/>
                    <field name="student_id"/>
                    <field name="student_name"/>
                    <field name="department_id"/>
                    <field name="date"/>
                    <field name="check_in_time" widget="datetime"/>
                    <field name="check_out_time" widget="datetime"/>
                    <field name="total_hours" string="Duration (Hours)"/>
                    <field name="late_time" string="Late (Time)"/>

                </list>

            </field>
        </record>

        <!-- ===================== -->
        <!-- GRAPH VIEW -->
        <!-- ===================== -->
        <record id="view_student_graph" model="ir.ui.view">
            <field name="name">student.attendance.graph</field>
            <field name="model">student.attendance</field>
            <field name="arch" type="xml">

                <graph string="Student Attendance Graph" type="bar">
    
                    <!-- X Axis -->
                    <field name="department_id"/>

                    <!-- Y Axis -->
                    <field name="total_hours" type="measure"/>

                </graph>

            </field>
        </record>

        <!-- ===================== -->
        <!-- SEARCH VIEW -->
        <!-- ===================== -->
        <record id="attendance_search" model="ir.ui.view">
            <field name="name">student.attendance.search</field>
            <field name="model">student.attendance</field>
            <field name="arch" type="xml">

                <search string="Search Students">

                    <!-- Search -->
                    <field name="student_name"/>

                    <!-- Late Filter -->
                    <filter name="late_arrival"
                            string="Late Arrival"
                            domain="[('late_time','!=','00:00:00')]"/>

                    <!-- Group By Department -->
                    <filter name="group_by_department"
                            string="Group by Department"
                            context="{'group_by': 'department_id'}"/>

                    <!-- Group By Late -->
                    <filter name="group_by_late"
                            string="Group by Late Arrival"
                            context="{'group_by': 'late_time'}"/>

                </search>

            </field>
        </record>
    </data>
</odoo>