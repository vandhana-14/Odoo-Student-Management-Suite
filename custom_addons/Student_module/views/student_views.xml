<odoo>
    <!-- ===================== -->
    <!-- LIST VIEW -->
    <!-- ===================== -->
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="name"/>
                <field name="student_code"/>
                <field name="department_id"/>
                <field name="mobile"/>
                <field name="age"/>
                <field name="skills" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- KANBAN VIEW -->
    <!-- ===================== -->
    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student.kanban</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            
            <kanban create="false">
                <templates>

                    <t t-name="card">
                        <div class="custom_card oe_kanban_global_click">

                            <!-- LEFT: IMAGE -->
                            <div class="card_left">
                                <field name="image"
                                    widget="image"
                                    options="{'size': [150, 150]}"/>
                            </div>

                            <!-- RIGHT: DETAILS -->
                            <div class="card_right">

                                <div class="card_name">
                                    <strong><field name="name"/></strong>
                                </div>

                                <div class="card_code">
                                    <field name="student_code"/>
                                </div>

                                <div class="card_email">
                                    <field name="email"/>
                                </div>

                                <!-- SKILLS -->
                                <div class="card_skills">
                                    <field name="skills" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </div>

                            </div>

                        </div>
                    </t>

                </templates>
            </kanban>

        </field>
    </record>

    <!-- ===================== -->
    <!-- PIVOT VIEW -->
    <!-- ===================== -->
    <record id="view_student_pivot" model="ir.ui.view">
        <field name="name">student.pivot</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">

            <pivot string="Student Analysis">

                <!-- ROW -->
                <field name="department_id" type="row"/>

                <!-- COLUMN -->
                <field name="gender" type="col"/>

                <!-- MEASURE -->
                <field name="age" type="measure"/>

            </pivot>

        </field>
    </record>

    <!-- ===================== -->
    <!-- GRAPH VIEW -->
    <!-- ===================== -->
    <record id="view_student_graph" model="ir.ui.view">
        <field name="name">student.graph</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">

            <graph string="Student Graph" type="bar">

                <!-- X Axis -->
                <field name="department_id"/>

                <!-- Y Axis -->
                <field name="age" type="measure"/>

            </graph>

        </field>
    </record>

    <!-- ===================== -->
    <!-- SEARCH VIEW -->
    <!-- ===================== -->
   <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.search</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">

            <search string="Search Students">

                <!-- Search -->
                <field name="name"/>

                <!-- Age Filter -->
                <filter name="age_gt_20"
                        string="Age > 20"
                        domain="[('age','>',20)]"/>
                
                <!-- Toggle Active Filter -->
                <filter name ="toggle"
                        string="Toggle Active"
                        domain="[('active','=',True)]"/>

                <!-- Toggle Inactivate Filter -->
                <filter name ="toggle2"
                        string="Toggle Inactive"
                        domain="[('active','=',False)]"/>


                <!-- Group By  Departments -->
                <filter name="group_by_department"
                        string="Group by Department"
                        context="{'group_by': 'department_id'}"/>

                <!-- Group By Age -->
                <filter name="group_by_age"
                        string="Group by Age"
                        context="{'group_by': 'age'}"/>

            </search>

        </field>
    </record>


</odoo>