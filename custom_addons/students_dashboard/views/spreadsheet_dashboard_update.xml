<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Update existing dashboard from students_app to avoid duplicate dashboards -->
        <record id="students_app.spreadsheet_dashboard_student" model="spreadsheet.dashboard">
            <field name="name">Student Dashboard</field>
            <field name="spreadsheet_binary_data" type="base64" file="students_dashboard/data/files/student_dashboard.json"/>
            <field name="main_data_model_ids" eval="[
                (6, 0, [
                    ref('students_app.model_student_student'),
                    ref('students_app.model_student_marks'),
                    ref('students_app.model_student_attendance'),
                    ref('students_app.model_student_leave'),
                    ref('students_app.model_student_marks_line'),
                    ref('students_app.model_student_exam')
                ])
            ]"/>
            <field name="is_published">True</field>
        </record>

    </data>
</odoo>
