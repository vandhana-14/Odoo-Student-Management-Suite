<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         Student Leave List View
    ========================== -->
    <record id="view_student_leave_list" model="ir.ui.view">
        <field name="name">student.leave.list</field>
        <field name="model">student.leave</field>
        <field name="arch" type="xml">

            <list>

                <!-- Top Buttons -->
                <header>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>

                </header>

                <field name="image"
                       widget="image"
                       options="{'size': [70,70]}"
                       class="oe_avatar"/>

                <field name="student_id"/>
                <field name="student_name"/>
                <field name="department_id"/>
                <field name="leave_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="days"/>

                <field name="state"
                       widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state == 'draft'"/>

                <field name="approved_by"/>

            </list>

        </field>
    </record>


    <!-- =========================
         Student Leave Form View
    ========================== -->
    <record id="view_student_leave_form" model="ir.ui.view">
        <field name="name">student.leave.form</field>
        <field name="model">student.leave</field>
        <field name="arch" type="xml">

            <form string="Student Leave">

                <!-- Header Buttons -->
                <header>

                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,approved,rejected"/>

                </header>

                <sheet>

                    <group>
                        <field name="student_id"/>
                        <field name="leave_type"/>
                    </group>

                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="days" readonly="1"/>
                    </group>

                    <group>
                        <field name="reason"/>
                    </group>

                    <!-- Hidden during draft -->
                    <group invisible="state == 'draft'">
                        <field name="approved_by"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- =====================
         GRAPH VIEW
    ===================== -->
    <record id="view_student_graph" model="ir.ui.view">
        <field name="name">student.leave.graph</field>
        <field name="model">student.leave</field>
        <field name="arch" type="xml">

            <graph string="Student Leave Graph" type="bar">

                <!-- X Axis -->
                <field name="department_id"/>

                <!-- Y Axis -->
                <field name="student_id" type="measure"/>

            </graph>

        </field>
    </record>


    <!-- =====================
         PIVOT VIEW
    ===================== -->
    <record id="view_leave_pivot" model="ir.ui.view">
        <field name="name">student.leave.pivot</field>
        <field name="model">student.leave</field>
        <field name="arch" type="xml">

            <pivot string="Leave Analysis">

                <field name="department_id" type="row"/>
                <field name="student_id" type="col"/>
                <field name="days" type="measure"/>

            </pivot>

        </field>
    </record>


    <!-- =====================
         SEARCH VIEW
    ===================== -->
    <record id="leave_search" model="ir.ui.view">
        <field name="name">student.leave.search</field>
        <field name="model">student.leave</field>
        <field name="arch" type="xml">

            <search string="Search Students">

                <field name="student_name"/>

                <filter name="long_leave"
                        string="Long Leave"
                        domain="[('days','>',3)]"/>

                <filter name="requested"
                        string="Requested"
                        domain="[('state','=','draft')]"/>

                <filter name="approved"
                        string="Approved"
                        domain="[('state','=','approved')]"/>

                <filter name="rejected"
                        string="Rejected"
                        domain="[('state','=','rejected')]"/>

                <filter name="group_by_department"
                        string="Group by Department"
                        context="{'group_by': 'department_id'}"/>

            </search>

        </field>
    </record>

</odoo>