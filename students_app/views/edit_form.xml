<odoo>

    <!-- ===================== -->
    <!-- EDIT FORM VIEW -->
    <!-- ===================== -->
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">student.student</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            
            <form string="Student"
                  create="false"
                  edit="true"
                  delete="true">

                <!-- HEADER BUTTONS -->
                <header>
                    <button name="action_update"
                            type="object"
                            string="Update"
                            class="btn-primary"/>

                    <button name="action_delete"
                            type="object"
                            string="Delete"
                            class="btn-secondary"/>
                </header>

                <sheet>

                    <!-- Hidden Role -->
                    <field name="role" invisible="1"/>

                    <!-- Dynamic Form Title -->
                    <div class="oe_title">

                        <h1 invisible="role != 'student'">
                            Student Profile
                        </h1>

                        <h1 invisible="role != 'staff'">
                            Staff Profile
                        </h1>

                        <h1 invisible="role != 'admin'">
                            Admin Profile
                        </h1>

                    </div>

                    <!-- NOTEBOOK (TABS) -->
                    <notebook>

                        <!-- ===================== -->
                        <!-- PERSONAL INFO -->
                        <!-- ===================== -->
                        <page string="Personal Info">

                            <group>
                                <group>

                                    <!-- Dynamic Name Label -->
                                    <field name="name"
                                           string="Student Name"
                                           invisible="role != 'student'"/>

                                    <field name="name"
                                           string="Staff Name"
                                           invisible="role != 'staff'"/>

                                    <field name="name"
                                           string="Admin Name"
                                           invisible="role != 'admin'"/>

                                    <field name="dob"/>
                                    <field name="age" readonly="1"/>
                                    <field name="gender"/>

                                </group>

                                <group>
                                    <field name="mobile"/>
                                    <field name="email"/>
                                    <field name="location"/>
                                    <field name="address"/>
                                </group>
                            </group>

                        </page>

                        <!-- ===================== -->
                        <!-- WORK INFO -->
                        <!-- ===================== -->
                        <page string="Work Info">

                            <group>
                                <group>
                                    <field name="department_id"
                                           options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="student_code"/>
                                    <field name="skills"
                                           widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                    <field name="joining_date"/>
                                </group>

                                <group>
                                    <field name="active" invisible="1"/>
                                    <field name="image"
                                           widget="image"
                                           options="{'preview_image': 'image', 'size': [150, 150]}"/>
                                </group>
                            </group>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

</odoo>