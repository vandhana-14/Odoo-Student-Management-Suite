<odoo>
    <data>

        <!-- ===================== -->
        <!-- ACTION (VIEW RECORDS) -->
        <!-- ===================== -->
        <record id="action_student" model="ir.actions.act_window">
            <field name="name">Student Records</field>
            <field name="res_model">student.student</field>

            <!-- View Order -->
            <field name="view_mode">list,kanban,form,pivot,graph</field>

            <!-- Default Views -->
            <field name="view_id" ref="view_student_list"/>
            <field name="search_view_id" ref="view_student_search"/>

            <!-- Context -->
            <field name="context">
                {
                    'create': 0,
                    'edit': 1
                }
            </field>

            <!-- Optional: Role Filter Ready -->
            <!-- No logic change, just prepared -->
            <field name="domain">[]</field>
        </record>



        <!-- ===================== -->
        <!-- ACTION (ENTRY FORM) -->
        <!-- ===================== -->
        <record id="action_student_entry" model="ir.actions.act_window">
            <field name="name">Create Entry</field>
            <field name="res_model">student.student</field>

            <field name="view_mode">form</field>
            <field name="view_id" ref="create_student_form"/>

            <field name="target">current</field>

            <field name="context">
                {
                    'create': 1,
                    'edit': 0
                }
            </field>
        </record>



        <!-- ===================== -->
        <!-- ATTENDANCE ACTION -->
        <!-- ===================== -->
        <record id="action_student_attendance" model="ir.actions.act_window">
            <field name="name">Attendance Records</field>
            <field name="res_model">student.attendance</field>

            <field name="view_mode">list,calendar,graph</field>

            <field name="search_view_id" ref="attendance_search"/>

            <!-- No logic change -->
            <field name="context">{}</field>
        </record>



        <!-- ===================== -->
        <!-- ATTENDANCE ENTRY -->
        <!-- ===================== -->
        <record id="action_student_attendance_entry" model="ir.actions.act_window">
            <field name="name">Attendance Entry</field>
            <field name="res_model">student.attendance</field>

            <field name="view_mode">form</field>
            <field name="view_id" ref="view_student_attendance_form"/>

            <field name="target">current</field>

            <!-- Prepared for role if needed -->
            <field name="context">{}</field>
        </record>
        
        <!-- Leave management -->

        <record id="action_student_leave" model="ir.actions.act_window">
            <field name="name">Student Leaves</field>
            <field name="res_model">student.leave</field>
            <field name="view_mode">list,pivot,graph,form</field>
        </record>

        <!-- =====================
            ACTION WINDOW
        ===================== -->
        <record id="action_student_marks" model="ir.actions.act_window">
            <field name="name">Student Marks</field>
            <field name="res_model">student.marks</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        <!-- Bulk Password Reset Action -->
        <record id="action_bulk_password_reset" model="ir.actions.act_window">
            <field name="name">Bulk Password Reset</field>
            <field name="res_model">student.bulk.password.reset</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Action to open Student Marks -->
        <record id="action_student_score" model="ir.actions.act_window">
            <field name="name">Semester Marks</field>
            <field name="res_model">student.score.record</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_student_score_list"/>
            <field name="search_view_id" ref="view_student_score_search"/>
            <field name="target">current</field>
        </record>

    </data>
</odoo>