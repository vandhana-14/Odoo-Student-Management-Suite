<odoo>

    <!-- Wizard Form View -->
    <record id="view_bulk_password_reset_form" model="ir.ui.view">
        <field name="name">bulk.password.reset.form</field>
        <field name="model">student.bulk.password.reset</field>
        <field name="arch" type="xml">

            <form string="Bulk Password Reset">

                <group>
                    <field name="student_ids" widget="many2many_tags"/>
                    <field name="new_password"/>
                </group>

                <footer>
                    <button name="action_reset_password"
                            type="object"
                            string="Reset Password"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>

            </form>

        </field>
    </record>

</odoo>