<odoo>

    <!-- ===================== -->
    <!-- CREATE FORM VIEW -->
    <!-- ===================== -->
    <record id="create_student_form" model="ir.ui.view">
        <field name="name">create_student.form</field>
        <field name="model">student.student</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <form string="Student"
                  create="true"
                  edit="false"
                  delete="false">

                <!-- ===================== -->
                <!-- HEADER -->
                <!-- ===================== -->
                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="btn-primary"/>

                    <button name="action_reset"
                            type="object"
                            string="Reset"
                            class="btn-secondary"/>
                </header>

                <!-- ===================== -->
                <!-- BODY -->
                <!-- ===================== -->
                <sheet>

                    <notebook>

                        <!-- ===================== -->
                        <!-- PERSONAL INFO -->
                        <!-- ===================== -->
                        <page string="Personal Info">

                            <group>
                                <group>
                                    <field name="role"/>
                                    <field name="name"/>
                                    <field name="dob"/>
                                    <field name="age" readonly="1"/>
                                    <field name="gender"/>
                                </group>

                                <group>
                                    <field name="mobile"/>
                                    <field name="email"/>
                                    <field name="location"/>
                                    <field name="address"/>
                                </group>
                            </group>

                        </page>

                        <!-- ===================== -->
                        <!-- WORK INFO -->
                        <!-- ===================== -->
                        <page string="Work Info">

                            <group>
                                <group>
                                    <field name="department_id"
                                           options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="student_code" readonly="1"/>
                                    <field name="skills"
                                           widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                    <field name="joining_date"/>
                                </group>

                                <group>
                                    <field name="active" invisible="1"/>
                                    <field name="image"
                                           widget="image"
                                           options="{'preview_image': 'image', 'size': [150, 150]}"/>
                                </group>
                            </group>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>

    </record>

</odoo>