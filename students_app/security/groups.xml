<odoo>
    <data>

        <!-- ========================= -->
        <!-- STUDENT ADMIN -->
        <!-- ========================= -->
        <record id="group_student_admin" model="res.groups">
            <field name="name">Student Admin</field>
            <!-- Must inherit internal user -->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ========================= -->
        <!-- STUDENT STAFF -->
        <!-- ========================= -->
        <record id="group_student_staff" model="res.groups">
            <field name="name">Student Staff</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ========================= -->
        <!-- STUDENT USER -->
        <!-- ========================= -->
        <record id="group_student_user" model="res.groups">
            <field name="name">Student User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>