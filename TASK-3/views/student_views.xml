<odoo>

    <!-- ===================== -->
    <!-- LIST VIEW -->
    <!-- ===================== -->
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="name"/>
                <field name="student_code"/>
                <field name="department_id"/>
                <field name="mobile"/>
                <field name="age"/>
                <field name="skills" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- EDIT FORM VIEW -->
    <!-- ===================== -->
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">student.student</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            
            <form string="Student" create="false" edit="true" delete="true">

                <header>
                    <button name="action_update"
                            type="object"
                            string="Update"
                            class="btn-primary"/>

                    <button name="action_delete"
                            type="object"
                            string="Delete"
                            class="btn-secondary"/>
                </header>

                <sheet>
                    <group string="Basic Info">
                        <group>
                            <field name="name"/>
                            <field name="student_code"/>
                            <field name="dob"/>
                            <field name="age" readonly="1"/>
                            <field name="gender"/>
                            <field name="department_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="skills" widget="many2many_tags"/>
                            <field name="joining_date"/>
                            <field name="active" invisible="1"/>
                            <field name="image"
                                   widget="image"
                                   options="{'preview_image': 'image', 'size': [150, 150]}"/>
                        </group>
                    </group>

                    <group string="Contact Details">
                        <group>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="location"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

    <!-- ===================== -->
    <!-- CREATE FORM VIEW -->
    <!-- ===================== -->
    <record id="create_student_form" model="ir.ui.view">
        <field name="name">create_student.form</field>
        <field name="model">student.student</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            
            <form string="Student" create="true" edit="false" delete="false">

                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="btn-primary"/>

                    <button name="action_reset"
                            type="object"
                            string="Reset"
                            class="btn-secondary"/>
                </header>

                <sheet>
                    <group string="Basic Info">
                        <group>
                            <field name="name"/>
                            <field name="student_code"/>
                            <field name="dob"/>
                            <field name="age" readonly="1"/>
                            <field name="gender"/>
                            <field name="department_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="skills" widget="many2many_tags"/>
                            <field name="joining_date"/>
                            <field name="active" invisible="1"/>
                            <field name="image"
                                   widget="image:"
                                   options="{'preview_image': 'image', 'size': [150, 150]}"/>
                        </group>
                    </group>

                    <group string="Contact Details">
                        <group>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="location"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>

            </form>
        </field>
    </record>

    <!-- ===================== -->
    <!-- KANBAN VIEW -->
    <!-- ===================== -->
    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student.kanban</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            
            <kanban create="false">
                <templates>

                    <t t-name="card" class="soe_kanban_card">
                        <div class="oe_kanban_global_click">

                            <field name="image"
                                   widget="image"
                                   options="{'preview_image': 'image', 'size': [150, 150]}"
                                   class="soe_kanban_image"/>
                            <div class="soe_kanban_details">
                                <strong>
                                    <field name="name"
                                    class="oe_kanban_title"/>
                                </strong>

                                <div>
                                    <field name="student_code"/>
                                </div>

                                <div>
                                    <field name="department_id"/>
                                </div>

                                <div>
                                    <field name="mobile"/>
                                </div>
                            </div>
                            <div>
                                <field name="skills" widget="many2many_tags"/>
                            </div>

                        </div>
                    </t>

                </templates>
            </kanban>

        </field>
    </record>

    <!-- ===================== -->
    <!-- ACTION (VIEW STUDENTS) -->
    <!-- ===================== -->
    <record id="action_student" model="ir.actions.act_window">
        <field name="name">View Students</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">list,form,kanban</field>

        <field name="view_id" ref="view_student_list"/>
        <field name="context">{'create': 0, 'edit': 1}</field>
    </record>

    <!-- ===================== -->
    <!-- ACTION (ADD STUDENT) -->
    <!-- ===================== -->
    <record id="action_student_entry" model="ir.actions.act_window">
        <field name="name">Add Student</field>
        <field name="res_model">student.student</field>

        <field name="view_mode">form</field>
        <field name="view_id" ref="create_student_form"/>

        <field name="target">current</field>
        <field name="context">{'create': 1}</field>
    </record>

</odoo>