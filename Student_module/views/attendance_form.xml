<odoo>
    <record id="view_student_attendance_form" model="ir.ui.view">
        <field name="name">student.attendance.form</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">

            <form string="Student Attendance">

                <header>
                    <button name="action_submit_attendance"
                            type="object"
                            string="Submit"
                            class="btn-primary"/>
                </header>

                <sheet>

                    <group>
                        <field name="student_id"/>
                        <field name="date" readonly="1"/>
                    </group>

                    <group>
                        <field name="check_in_time"/>
                        <field name="check_out_time"/>
                    </group>

                    <group>
                        <field name="late_time" readonly="1"/>
                        <field name="total_hours" readonly="1"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>


</odoo>